async function loadManageEvents() {
    console.log('Loading manage events...');
    
    const container = document.getElementById('eventsContainer');
    container.innerHTML = '<p style="text-align: center; color: #666; padding: 2rem;">Loading events...</p>';
    
    try {
        const eventsQuery = window.query(
            window.collection(window.db, 'events'),
            window.orderBy('eventDate', 'desc')
        );
        
        const querySnapshot = await window.getDocs(eventsQuery);
        console.log('Events loaded:', querySnapshot.size);
        
        container.innerHTML = '';
        
        if (querySnapshot.empty) {
            container.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-calendar-alt"></i>
                    <h3>No events yet</h3>
                    <p>Create your first event to get started!</p>
                </div>
            `;
            return;
        }
        
        querySnapshot.forEach((doc) => {
            const event = doc.data();
            const eventCard = createEventCard(doc.id, event);
            container.appendChild(eventCard);
        });
        
    } catch (error) {
        console.error('Error loading events:', error);
        container.innerHTML = '<p style="text-align: center; color: #c33; padding: 2rem;">Error loading events.</p>';
    }
}

// Create Event Card with Edit functionality
function createEventCard(id, event) {
    const card = document.createElement('div');
    card.className = 'item-card';
    
    const eventDate = event.eventDate.toDate ? event.eventDate.toDate() : new Date(event.eventDate);
    const dateString = formatDate(eventDate);
    const timeString = eventDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
    
    const isPast = eventDate < new Date();
    const statusColor = isPast ? '#ef4444' : '#10b981';
    const statusText = isPast ? 'Past' : 'Upcoming';
    
    // Check if current user is the author
    const isAuthor = currentUser && event.authorId === currentUser.uid;
    const authorBadge = isAuthor ? '<span class="author-badge">Your Event</span>' : '';
    
    card.innerHTML = `
        <div class="item-info">
            <h3 class="item-title">${event.title}</h3>
            <div class="item-meta">
                <span class="item-category" style="background: ${statusColor};">
                    ${statusText}
                </span>
                ${authorBadge}
                <span>📅 ${dateString} at ${timeString}</span>
                <span>👤 ${event.publisher}</span>
                <span>✉️ ${event.createdBy || event.authorEmail || 'Unknown'}</span>
                ${event.lastModifiedBy && event.lastModifiedBy !== event.createdBy ? 
                    `<span>✏️ Edited by ${event.lastModifiedBy}</span>` : ''}
            </div>
        </div>
        <div class="item-actions">
            <button class="btn-edit" onclick="editEvent('${id}')">
                <i class="fas fa-edit"></i> Edit
            </button>
            <button class="btn-delete" onclick="deleteEvent('${id}')">
                <i class="fas fa-trash"></i> Delete
            </button>
        </div>
    `;
    
    return card;
}

// Edit Event - Load data into modal
window.editEvent = async function(eventId) {
    console.log('Editing event:', eventId);
    showLoading(true);
    
    try {
        const docSnap = await window.getDoc(window.doc(window.db, 'events', eventId));
        
        if (!docSnap.exists()) {
            throw new Error('Event not found');
        }
        
        const event = docSnap.data();
        const eventDate = event.eventDate.toDate ? event.eventDate.toDate() : new Date(event.eventDate);
        
        // Populate form
        document.getElementById('eventTitle').value = event.title;
        document.getElementById('eventDescription').value = event.description;
        document.getElementById('eventDate').value = eventDate.toISOString().split('T')[0];
        document.getElementById('eventTime').value = eventDate.toTimeString().slice(0, 5);
        document.getElementById('eventPublisher').value = event.publisher;
        
        // Show existing image if exists
        if (event.imageUrl) {
            document.getElementById('eventImagePreview').innerHTML = 
                `<img src="${event.imageUrl}" alt="Current Image">`;
        }
        
        // Set modal to edit mode
        document.getElementById('eventForm').dataset.mode = 'update';
        document.getElementById('eventForm').dataset.eventId = eventId;
        document.querySelector('#eventModal .modal-header h2').textContent = 'Edit Event';
        document.querySelector('#eventForm button[type="submit"]').innerHTML = '<i class="fas fa-save"></i> Update Event';
        
        // Open modal
        eventModal.classList.add('show');
        document.body.style.overflow = 'hidden';
        
        showLoading(false);
        
    } catch (error) {
        showLoading(false);
        console.error('Error loading event:', error);
        alert('Error loading event: ' + error.message);
    }
};

// Delete Event
window.deleteEvent = async function(eventId) {
    if (!confirm('Are you sure you want to delete this event? This action cannot be undone.')) return;
    
    console.log('Deleting event:', eventId);
    showLoading(true);
    
    try {
        await window.deleteDoc(window.doc(window.db, 'events', eventId));
        console.log('Event deleted successfully');
        showLoading(false);
        showToast('Event deleted successfully! ✅');
        loadManageEvents();
        loadDashboardStats();
    } catch (error) {
        showLoading(false);
        console.error('Error deleting event:', error);
        alert('Error deleting event: ' + error.message);
    }
};

// ========== FILTERS ==========

// Filter Posts
document.getElementById('filterCategory').addEventListener('change', async function() {
    const category = this.value;
    console.log('Filtering posts by category:', category);
    
    const container = document.getElementById('postsContainer');
    container.innerHTML = '<p style="text-align: center; color: #666; padding: 2rem;">Loading posts...</p>';
    
    try {
        let postsQuery;
        
        if (category === 'all') {
            postsQuery = window.query(
                window.collection(window.db, 'posts'),
                window.orderBy('createdAt', 'desc')
            );
        } else {
            postsQuery = window.query(
                window.collection(window.db, 'posts'),
                window.where('category', '==', category),
                window.orderBy('createdAt', 'desc')
            );
        }
        
        const querySnapshot = await window.getDocs(postsQuery);
        container.innerHTML = '';
        
        if (querySnapshot.empty) {
            container.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-newspaper"></i>
                    <h3>No posts found</h3>
                    <p>No posts in this category yet.</p>
                </div>
            `;
            return;
        }
        
        querySnapshot.forEach((doc) => {
            const post = doc.data();
            const postCard = createPostCard(doc.id, post);
            container.appendChild(postCard);
        });
        
    } catch (error) {
        console.error('Error filtering posts:', error);
        container.innerHTML = '<p style="text-align: center; color: #c33; padding: 2rem;">Error loading posts.</p>';
    }
});

// Filter Events
document.getElementById('filterEventStatus').addEventListener('change', async function() {
    const status = this.value;
    console.log('Filtering events by status:', status);
    
    const container = document.getElementById('eventsContainer');
    container.innerHTML = '<p style="text-align: center; color: #666; padding: 2rem;">Loading events...</p>';
    
    try {
        const now = new Date();
        let eventsQuery;
        
        if (status === 'all') {
            eventsQuery = window.query(
                window.collection(window.db, 'events'),
                window.orderBy('eventDate', 'desc')
            );
        } else if (status === 'upcoming') {
            eventsQuery = window.query(
                window.collection(window.db, 'events'),
                window.where('eventDate', '>=', now),
                window.orderBy('eventDate', 'asc')
            );
        } else if (status === 'past') {
            eventsQuery = window.query(
                window.collection(window.db, 'events'),
                window.where('eventDate', '<', now),
                window.orderBy('eventDate', 'desc')
            );
        }
        
        const querySnapshot = await window.getDocs(eventsQuery);
        container.innerHTML = '';
        
        if (querySnapshot.empty) {
            container.innerHTML = `
                <div class="empty-state">
                    <i class="fas fa-calendar-alt"></i>
                    <h3>No events found</h3>
                    <p>No ${status} events.</p>
                </div>
            `;
            return;
        }
        
        querySnapshot.forEach((doc) => {
            const event = doc.data();
            const eventCard = createEventCard(doc.id, event);
            container.appendChild(eventCard);
        });
        
    } catch (error) {
        console.error('Error filtering events:', error);
        container.innerHTML = '<p style="text-align: center; color: #c33; padding: 2rem;">Error loading events.</p>';
    }
});

// ========== UTILITY FUNCTIONS ==========

function formatDate(date) {
    return date.toLocaleDateString('en-US', { 
        year: 'numeric', 
        month: 'short', 
        day: 'numeric' 
    });
}

function showToast(message) {
    const toast = document.getElementById('toast');
    document.getElementById('toastMessage').textContent = message;
    toast.classList.add('show');
    
    setTimeout(() => {
        toast.classList.remove('show');
    }, 3000);
}

function showLoading(show) {
    const overlay = document.getElementById('loading');
    if (show) {
        overlay.classList.add('show');
    } else {
        overlay.classList.remove('show');
    }
}

console.log('Multi-Admin Dashboard JS initialization complete!');